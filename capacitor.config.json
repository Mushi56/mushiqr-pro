{
  "appId": "com.mushiqr.pro",
  "appName": "Mushi Qr Pro",
  "webDir": "dist",
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#13131D",
      "overlaysWebView": false,
      "androidStatusBarPadding": false
    },
    "Camera": {
      "presentationStyle": "fullscreen"
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https"
  }
}
